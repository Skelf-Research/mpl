{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:stype:org.calendar.Event.v1",
  "title": "Calendar Event",
  "description": "A scheduled event with start/end times and optional attendees.",
  "type": "object",
  "properties": {
    "eventId": {
      "type": "string",
      "description": "Unique identifier for the event.",
      "pattern": "^evt_[a-zA-Z0-9]+$",
      "examples": ["evt_001", "evt_abc123"]
    },
    "title": {
      "type": "string",
      "description": "Event title or subject.",
      "minLength": 1,
      "maxLength": 200,
      "examples": ["Design Review", "Team Standup", "Project Kickoff"]
    },
    "start": {
      "type": "string",
      "format": "date-time",
      "description": "Event start time in ISO 8601 format (UTC).",
      "examples": ["2025-10-27T13:00:00Z", "2025-11-05T09:30:00Z"]
    },
    "end": {
      "type": "string",
      "format": "date-time",
      "description": "Event end time in ISO 8601 format (UTC). Must be after start time.",
      "examples": ["2025-10-27T13:30:00Z", "2025-11-05T10:00:00Z"]
    },
    "attendees": {
      "type": "array",
      "description": "List of attendee email addresses.",
      "items": {
        "type": "string",
        "format": "email"
      },
      "uniqueItems": true,
      "maxItems": 100,
      "examples": [
        ["alice@example.com", "bob@example.com"],
        ["team@example.com"]
      ]
    },
    "location": {
      "type": "string",
      "description": "Physical or virtual location of the event.",
      "maxLength": 500,
      "examples": ["Conference Room A", "https://meet.example.com/abc-123", "Building 1, Floor 3"]
    },
    "description": {
      "type": "string",
      "description": "Detailed event description or agenda.",
      "maxLength": 2000,
      "examples": ["Quarterly planning session with engineering leads."]
    },
    "status": {
      "type": "string",
      "enum": ["pending", "confirmed", "cancelled"],
      "description": "Event status.",
      "default": "pending"
    }
  },
  "required": ["eventId", "title", "start", "end"],
  "additionalProperties": false,
  "version": "1.0.0",
  "changelog": [
    {
      "version": "1.0.0",
      "date": "2025-10-01",
      "changes": "Initial release with core event fields."
    }
  ]
}
