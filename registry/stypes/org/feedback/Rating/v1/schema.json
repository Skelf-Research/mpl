{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:stype:org.feedback.Rating.v1",
  "title": "Feedback Rating",
  "description": "A user rating or feedback entry",
  "type": "object",
  "properties": {
    "ratingId": {
      "type": "string"
    },
    "targetType": {
      "type": "string",
      "enum": ["response", "tool", "agent", "workflow", "content"]
    },
    "targetId": {
      "type": "string"
    },
    "rating": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "feedback": {
      "type": "string",
      "maxLength": 5000
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["helpful", "accurate", "fast", "creative", "not-helpful", "inaccurate", "slow", "off-topic"]
      }
    },
    "userId": {
      "type": "string"
    },
    "sessionId": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["targetType", "targetId", "rating"]
}
