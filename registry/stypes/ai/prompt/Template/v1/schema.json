{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:stype:ai.prompt.Template.v1",
  "title": "Prompt Template",
  "description": "A reusable prompt template with variables",
  "type": "object",
  "properties": {
    "templateId": {
      "type": "string",
      "description": "Unique template identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "template": {
      "type": "string",
      "minLength": 1,
      "description": "The prompt template with {{variable}} placeholders"
    },
    "variables": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["string", "number", "boolean", "array", "object"] },
          "required": { "type": "boolean", "default": true },
          "default": {},
          "description": { "type": "string" }
        },
        "required": ["name", "type"]
      }
    },
    "systemPrompt": {
      "type": "string",
      "description": "Optional system prompt to prepend"
    },
    "outputSchema": {
      "type": "object",
      "description": "Expected output JSON Schema"
    },
    "config": {
      "type": "object",
      "properties": {
        "model": { "type": "string" },
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "maxTokens": { "type": "integer", "minimum": 1 }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "version": {
      "type": "string"
    }
  },
  "required": ["templateId", "name", "template"]
}
