{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:stype:org.agent.TaskPlan.v1",
  "title": "Agent Task Plan",
  "description": "A structured plan for agent task execution",
  "type": "object",
  "properties": {
    "planId": {
      "type": "string",
      "description": "Unique identifier for the plan"
    },
    "goal": {
      "type": "string",
      "description": "High-level goal to achieve"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "stepId": { "type": "string" },
          "description": { "type": "string" },
          "tool": { "type": "string", "description": "Tool ID to invoke" },
          "args": { "type": "object" },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Step IDs this step depends on"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "failed", "skipped"]
          }
        },
        "required": ["stepId", "description"]
      }
    },
    "context": {
      "type": "object",
      "description": "Context variables for the plan"
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Constraints to observe during execution"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "ready", "executing", "completed", "failed"]
    }
  },
  "required": ["goal", "steps"],
  "additionalProperties": false
}
