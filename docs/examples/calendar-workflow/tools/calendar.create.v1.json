{
  "id": "calendar.create.v1",
  "name": "calendar.create",
  "version": "1.0.0",
  "description": "Create a new calendar event.",
  "args_stype": "org.calendar.Event.v1",
  "returns_stype": "org.calendar.Event.v1",
  "policies": ["policy.ref#consent-basic-v1"],
  "profiles": ["qom-strict-argcheck", "qom-basic"],
  "features": ["recurrence", "attendee_roles"],
  "idempotent": true,
  "side_effects": ["write"],
  "impl": {
    "type": "http",
    "url": "https://api.example.com/v1/calendar/events",
    "method": "POST",
    "auth": "bearer",
    "timeout_ms": 5000
  },
  "examples": [
    {
      "description": "Create a simple meeting",
      "input": {
        "eventId": "evt_001",
        "title": "Design Review",
        "start": "2025-10-27T13:00:00Z",
        "end": "2025-10-27T13:30:00Z",
        "attendees": ["alice@example.com", "bob@example.com"]
      },
      "output": {
        "eventId": "evt_001",
        "title": "Design Review",
        "start": "2025-10-27T13:00:00Z",
        "end": "2025-10-27T13:30:00Z",
        "attendees": ["alice@example.com", "bob@example.com"],
        "status": "confirmed"
      }
    }
  ],
  "errors": [
    {
      "code": "E-EVENT-CONFLICT",
      "description": "Event overlaps with existing event.",
      "remediation": "Choose a different time slot or cancel conflicting event."
    },
    {
      "code": "E-INVALID-ATTENDEE",
      "description": "Attendee email address is invalid or not found.",
      "remediation": "Verify attendee email addresses."
    }
  ]
}
