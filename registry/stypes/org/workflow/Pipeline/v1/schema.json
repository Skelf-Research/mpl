{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:stype:org.workflow.Pipeline.v1",
  "title": "Workflow Pipeline",
  "description": "A complete workflow pipeline with multiple steps",
  "type": "object",
  "properties": {
    "pipelineId": {
      "type": "string",
      "description": "Unique pipeline identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Pipeline name"
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "urn:stype:org.workflow.Step.v1"
      },
      "minItems": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "paused", "completed", "failed", "cancelled"]
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["manual", "schedule", "event", "webhook"] },
          "config": { "type": "object" }
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": true,
      "description": "Shared context across steps"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "required": ["pipelineId", "name", "steps"]
}
