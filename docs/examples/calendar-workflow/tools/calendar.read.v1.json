{
  "id": "calendar.read.v1",
  "name": "calendar.read",
  "version": "1.0.0",
  "description": "Read calendar events by query parameters.",
  "args_stype": "org.calendar.Query.v1",
  "returns_stype": "org.calendar.EventList.v1",
  "policies": ["policy.ref#consent-basic-v1"],
  "profiles": ["qom-basic"],
  "features": [],
  "idempotent": true,
  "side_effects": ["read"],
  "impl": {
    "type": "http",
    "url": "https://api.example.com/v1/calendar/events",
    "method": "GET",
    "auth": "bearer",
    "timeout_ms": 3000
  },
  "examples": [
    {
      "description": "Query events by ID",
      "input": {
        "eventId": "evt_001"
      },
      "output": {
        "events": [
          {
            "eventId": "evt_001",
            "title": "Design Review",
            "start": "2025-10-27T13:00:00Z",
            "end": "2025-10-27T13:30:00Z",
            "status": "confirmed"
          }
        ]
      }
    }
  ]
}
