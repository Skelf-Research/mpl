{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:stype:org.calendar.Query.v1",
  "title": "Calendar Query",
  "description": "Query parameters for searching calendar events.",
  "type": "object",
  "properties": {
    "eventId": {
      "type": "string",
      "description": "Unique event identifier for direct lookup.",
      "pattern": "^evt_[a-zA-Z0-9]+$"
    },
    "startAfter": {
      "type": "string",
      "format": "date-time",
      "description": "Return events starting after this timestamp."
    },
    "startBefore": {
      "type": "string",
      "format": "date-time",
      "description": "Return events starting before this timestamp."
    },
    "attendee": {
      "type": "string",
      "format": "email",
      "description": "Filter events by attendee email."
    },
    "status": {
      "type": "string",
      "enum": ["pending", "confirmed", "cancelled"],
      "description": "Filter by event status."
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 10,
      "description": "Maximum number of results to return."
    }
  },
  "additionalProperties": false,
  "version": "1.0.0"
}
